---
import BaseLayout from "../layouts/BaseLayout.astro";
import Section from "../components/Section.astro";
import Entry from "../components/Entry.astro";

const postmortems = [
	{
		title: "Gnome Trader",
		meta: "DISCONTINUED",
		href: "/postmortems/gnome-trader",
		summary:
			"Autonomous Solana trading platform. Original thesis, what worked, what failed, and what I would do differently. Includes architecture and operational notes.",
		tags: ["solana", "trading", "autonomous"],
	},
	{
		title: "GnomeAIO",
		meta: "DISCONTINUED",
		href: "/postmortems/gnome-aio",
		summary:
			"Multi-agent orchestration platform for headless game clients. Architecture, the feedback loops it closed, where the design held under load, where it didn't.",
		tags: ["multi-agent", "orchestration", "autonomous"],
	},
];
---

<BaseLayout title="postmortems" section="POSTMORTEMS">

	<Section title="NAME">
		<p>postmortems</p>
	</Section>

	<Section title="DESCRIPTION">
		<p>
		Why they died.	
		</p>
	</Section>

	<Section title="INDEX">
		<div class="space-y-6">
			{postmortems.map((p) => (
				<Entry title={p.title} meta={p.meta} href={p.href} tags={p.tags}>
					{p.summary}
				</Entry>
			))}
		</div>
	</Section>

</BaseLayout>
