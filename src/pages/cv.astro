---
import BaseLayout from "../layouts/BaseLayout.astro";
import Section from "../components/Section.astro";
import DefList from "../components/DefList.astro";

const experience = [
	{
		role: "Lead Software Engineer",
		org: "SECOM Plc",
		period: "Sep 2024 — Present",
		bullets: [
			"Technical lead building a new business platform for both internal and customer use with Python, FastAPI, React, TypeScript, and Redis.",
			"Designed and built event-driven backend services that synchronise operational data across on-premises and third-party systems.",
			"Migrating legacy MySQL platforms onto a unified service-based architecture without downtime.",
			"Replacing manual workflows and document generation across the organisation.",
			"Own architecture, CI/CD, and operational reliability across all services on Google Cloud.",
		],
	},
	{
		role: "Systems Engineer",
		org: "British Steel",
		period: "Jan 2024 — Sep 2024",
		bullets: [
			"Designed a molten steel tracking system to capture material used and wasted across the plant.",
			"Built data pipelines combining Digital Matter GPS telemetry, on-site sensor feeds, and legacy systems to support real-time logistics and production decisions.",
			"Interfaced with legacy Fortran and COBOL systems running critical production and financial reporting workflows.",
			"Built datasets used by operations for cost tracking, efficiency analysis, and production optimisation.",
		],
	},
	{
		role: "Software / Electronics Engineer",
		org: "Lampada",
		period: "Jun 2022 — Jan 2024",
		bullets: [
			"Built a GPS-based campus navigation app for the University of Hull, with pathfinding around campus buildings and walkways.",
			"Designed and prototyped custom PCBs for client projects, from schematic capture through layout to manufacture.",
		],
	},
	{
		role: "Hydraulics Technician",
		org: "Siemens Gamesa",
		period: "May 2018 — Sep 2019",
		bullets: [
			"Built, calibrated, and serviced high-pressure hydraulic systems and devices used across the wind turbine industry.",
		],
	},
	{
		role: "Offshore Wind Turbine Technician",
		org: "E.ON Energy",
		period: "Sep 2015 — May 2018",
		bullets: [
			"Hands-on mechanical, electrical, and hydraulic maintenance of offshore wind turbines, with direct responsibility for turbine availability and generation uptime.",
			"Fault diagnosis and resolution using SCADA telemetry and on-site instrumentation across power generation, control, and safety systems.",
			"Worked under strict safety, working-at-height, and offshore-access certifications (GWO standards) in a remote, weather-constrained operational environment.",
		],
	},
	{
		role: "Software Engineer",
		org: "Gnome Trader (Personal Project)",
		period: "Mar 2024 — Jan 2026",
		bullets: [
			"Reduced end-to-end delivery latency from approximately one hour of manual processing to sub-20-second automated execution.",
			"Designed and built a distributed Solana payment and delivery platform. Python, FastAPI, WebSockets, Redis, PostgreSQL, atomic Lua-scripted Redis claims with TTL self-healing.",
			"Verified on-chain Solana transactions before triggering downstream fulfilment, with idempotent payment processing and tolerance-window amount matching.",
		],
	},
];

const education = {
	institution: "University of Hull",
	degree: "BSc Robotics and Mechatronics (2:1)",
	period: "Sep 2019 — May 2022",
};

const skills = [
	{ term: "backend", value: "Python services, FastAPI, async workflows, API integration" },
	{ term: "frontend", value: "React, JavaScript, TypeScript, Phantom Wallet" },
	{ term: "data & state", value: "PostgreSQL, reconciliation logic, idempotent processing" },
	{ term: "real-time", value: "WebSockets, event-driven architectures, concurrent task coordination" },
	{ term: "cloud", value: "Google Cloud (Cloud Run, managed services, virtual machines), Pulumi" },
	{ term: "crypto", value: "Solana transactions, on-chain verification, settlement flows" },
];
---

<BaseLayout title="cv" section="CV">

	<section class="mb-12 grid grid-cols-[1fr_auto] gap-6 sm:gap-8 items-start">
		<div>
			<h2 class="text-xs font-semibold uppercase tracking-[0.22em] text-ink-soft mb-4 border-b border-dashed border-[var(--color-rule-strong)] pb-1">
				NAME
			</h2>
			<p class="text-[15px] leading-relaxed">
				brad gooseman — cybernetics · autonomous systems · automation
			</p>
		</div>
		<figure class="w-28 sm:w-36 shrink-0">
			<img
				src="/images/brad-halftone.png"
				alt="Halftone portrait of Brad Gooseman"
				width="400"
				height="419"
				class="w-full h-auto border border-dashed border-[var(--color-rule-strong)] p-1.5 bg-[var(--color-paper)]"
			/>
			<figcaption class="text-[10.5px] uppercase tracking-[0.2em] text-ink-soft mt-2 text-center">
				fig. 1 · gooseman
			</figcaption>
		</figure>
	</section>

	<Section title="DESCRIPTION">
		<p>
			I have worked across many disciplines in the engineering world.
			Hands-on maintenance and troubleshooting on offshore wind
			turbines at E.ON Energy. Electronics and control systems
			through a Robotics and Mechatronics degree at Hull. Industrial
			systems engineering at British Steel, working with telemetry,
			sensors, and legacy production systems. Software engineering
			at SECOM Plc and on my own ventures.
		</p>
		<p>
			All of it is control systems work. The vocabulary is the same
			whether the system is a turbine, a steel plant, or a business
			platform: sensors, actuators, controllers, feedback loops,
			disturbances. I work mostly in software because of my interest
			in fully autonomous commercial businesses. They are lagging
			behind everyone else, and the opportunities for change are
			massive.
		</p>
		<p>
			At <span class="text-ink">SECOM UK</span> I am replacing all
			legacy systems and automating every aspect of the business.
			The goal is to put the entire company onto a USB stick.
		</p>
	</Section>

	<Section title="EXPERIENCE">
		<div class="space-y-6">
			{experience.map((e) => (
				<div class="border-l-2 border-[var(--color-rule-strong)] pl-4">
					<div class="flex flex-wrap items-baseline justify-between gap-x-4">
						<h3 class="text-base font-semibold">{e.role}, {e.org}</h3>
						<span class="text-xs text-ink-soft uppercase tracking-widest">{e.period}</span>
					</div>
					<ul class="mt-2 space-y-1 text-[14.5px] text-ink-soft leading-relaxed list-none">
						{e.bullets.map((b) => (
							<li class="flex gap-2">
								<span aria-hidden="true" class="shrink-0">·</span>
								<span>{b}</span>
							</li>
						))}
					</ul>
				</div>
			))}
		</div>
	</Section>

	<Section title="EDUCATION">
		<div class="border-l-2 border-[var(--color-rule-strong)] pl-4">
			<div class="flex flex-wrap items-baseline justify-between gap-x-4">
				<h3 class="text-base font-semibold">{education.degree}, {education.institution}</h3>
				<span class="text-xs text-ink-soft uppercase tracking-widest">{education.period}</span>
			</div>
		</div>
	</Section>

	<Section title="SKILLS">
		<DefList items={skills} />
	</Section>

	<Section title="DOWNLOAD">
		<p>
			<a href="/cv.pdf">view pdf</a> &nbsp; · &nbsp; <a href="/cv.pdf" download>download pdf</a>
		</p>
	</Section>

</BaseLayout>
