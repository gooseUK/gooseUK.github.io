---
import BaseLayout from "../layouts/BaseLayout.astro";
import Section from "../components/Section.astro";
import Entry from "../components/Entry.astro";

const projects = [
	{
		title: "Gnome Trader",
		meta: "POSTMORTEM",
		href: "/projects/gnome-trader",
		summary:
			"Autonomous trading platform built around the Solana ecosystem. Strategy execution, exchange integration, monitoring. Discontinued.",
		tags: ["solana", "trading", "autonomous", "infra"],
	},
	{
		title: "GnomeAIO",
		meta: "POSTMORTEM",
		href: "/projects/gnome-aio",
		summary:
			"Visual programming environment for RuneScape bots. Players compose bot behaviour by wiring nodes in a React Flow graph editor, and Java bots walk the graphs in-game with a live trace of the currently-executing node back to the browser. Discontinued.",
		tags: ["visual-programming", "graph-walker", "react-flow", "sse"],
	},
];
---

<BaseLayout title="projects" section="PROJECTS">

	<Section title="NAME">
		<p>projects</p>
	</Section>

	<Section title="INDEX">
		<div class="space-y-6">
			{projects.map((p) => (
				<Entry title={p.title} meta={p.meta} href={p.href} tags={p.tags}>
					{p.summary}
				</Entry>
			))}
		</div>
	</Section>

	<Section title="NOTES">
		<p class="text-ink-soft">
			Each project page covers the problem, the architecture, and the engineering
			decisions. Finished projects also include a postmortem on what worked and what
			did not.
		</p>
	</Section>

</BaseLayout>
