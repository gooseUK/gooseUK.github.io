---
interface Props {
	caption?: string;
}

const { caption } = Astro.props;
---

<figure class="my-6">
	<div class="border border-dashed border-[var(--color-rule-strong)] p-1.5 bg-[var(--color-paper-shade)]">
		<slot />
	</div>
	{caption && (
		<figcaption class="text-[10.5px] uppercase tracking-[0.2em] text-ink-soft mt-2 text-center">
			{caption}
		</figcaption>
	)}
</figure>
