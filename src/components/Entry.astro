---
interface Props {
	title: string;
	meta?: string;
	href?: string;
	tags?: string[];
}
const { title, meta, href, tags } = Astro.props;
const Tag = href ? "a" : "div";
---

<article class="group">
	<Tag
		href={href}
		class:list={[
			"block border-l-2 border-[var(--color-rule-strong)] pl-4 py-1",
			href && "no-underline hover:!bg-transparent hover:border-ink",
		]}
	>
		<div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1">
			<h3 class="text-base font-semibold tracking-tight">
				{href ? <span class="group-hover:underline underline-offset-4 decoration-1">{title}</span> : title}
			</h3>
			{meta && <span class="text-xs text-ink-soft uppercase tracking-widest">{meta}</span>}
		</div>
		<div class="mt-1 text-[14.5px] text-ink-soft leading-relaxed">
			<slot />
		</div>
		{tags && tags.length > 0 && (
			<ul class="mt-2 flex flex-wrap gap-x-3 gap-y-1 text-[11.5px] uppercase tracking-[0.15em] text-ink-soft">
				{tags.map((t) => <li>· {t}</li>)}
			</ul>
		)}
	</Tag>
</article>
